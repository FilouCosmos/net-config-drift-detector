import difflib
from typing import List, Dict, Optional
from colorama import init, Fore
from netmiko import ConnectHandler, NetmikoTimeoutException, NetmikoAuthenticationException

init(autoreset=True)

# --- Configuration ---
FICHIER_GOLDEN_CONFIG = "golden_config.txt"

# Modifiez ceci avec les infos de votre équipement de test
EQUIPEMENT_CIBLE = {
    'device_type': 'cisco_ios', # ou 'juniper', 'linux', etc.
    'host':   '192.168.1.10',
    'username': 'admin',
    'password': 'SuperPassword123!',
    'secret': 'EnablePassword123!',
}
# ---------------------

def lire_golden_config(chemin_fichier: str) -> Optional[str]:
    """Lit le fichier de configuration de référence en local."""
    try:
        with open(chemin_fichier, 'r') as f:
            return f.read()
    except FileNotFoundError:
        print(f"{Fore.RED}Erreur : Le fichier {chemin_fichier} est introuvable.")
        return None

def recuperer_config_actuelle(device_params: Dict[str, str]) -> Optional[str]:
    """Se connecte en SSH et lance 'show running-config'."""
    print(f"Connexion à {device_params['host']} en cours...")
    try:
        with ConnectHandler(**device_params) as net_connect:
            net_connect.enable()
            return net_connect.send_command("show running-config")
    except Exception as e:
        print(f"{Fore.RED}Erreur de connexion SSH : {e}")
    return None

def detecter_derive(config_ref: str, config_test: str) -> List[str]:
    """Génère la différence unifiée entre les deux configurations."""
    lignes_ref = config_ref.strip().splitlines()
    lignes_test = config_test.strip().splitlines()
    diff = difflib.unified_diff(
        lignes_ref, lignes_test, 
        fromfile='Golden_Config', tofile='Running_Config', lineterm=''
    )
    return list(diff)

if __name__ == "__main__":
    golden_conf = lire_golden_config(FICHIER_GOLDEN_CONFIG)
    
    if golden_conf:
        running_conf = recuperer_config_actuelle(EQUIPEMENT_CIBLE)
        
        if running_conf:
            rapport = detecter_derive(golden_conf, running_conf)
            
            if rapport:
                print(f"\n{Fore.YELLOW}! DÉRIVE DE CONFIGURATION DÉTECTÉE ⚠️\n")
                for ligne in rapport:
                    if ligne.startswith('+') and not ligne.startswith('+++'):
                        print(f"{Fore.GREEN}{ligne}")
                    elif ligne.startswith('-') and not ligne.startswith('---'):
                        print(f"{Fore.RED}{ligne}")
                    else:
                        print(ligne)
            else:
                print(f"\n{Fore.GREEN} Aucune dérive détectée. L'équipement est conforme.")